-- 模块二：传送功能 (自定义点位与1秒30次传送)
-- ==========================================
Tabs.Teleport:AddSection("坐标捕获与传送")

local savedPositions = {}
local customSaveName = "未命名点位"
local selectedSaveSlot = "无数据"
local loopTpEnabled = false
local TpDropdownObj = nil 

Tabs.Teleport:AddInput("SaveNameInput", {
    Title = "保存位置名称",
    Default = "未命名点位",
    Placeholder = "输入你要保存的名称...",
    Numeric = false,
    Finished = false,
    Callback = function(value)
        customSaveName = value
    end
})

local function updateTpDropdown()
    local list = {}
    for name, _ in pairs(savedPositions) do table.insert(list, name) end
    if #list == 0 then table.insert(list, "无数据") end
    
    if TpDropdownObj then
        TpDropdownObj:SetValues(list)
        if selectedSaveSlot == "无数据" or not savedPositions[selectedSaveSlot] then
            selectedSaveSlot = list[1]
            TpDropdownObj:SetValue(list[1])
        end
    end
end

Tabs.Teleport:AddButton({
    Title = "保存当前位置",
    Callback = function()
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            savedPositions[customSaveName] = hrp.CFrame
            updateTpDropdown()
            Fluent:Notify({ Title = "保存成功", Content = "已保存坐标: " .. customSaveName, Duration = 2 })
        end
    end
})

TpDropdownObj = Tabs.Teleport:AddDropdown("TpSlotSelect", {
    Title = "选择目标位置",
    Values = {"无数据"},
    Default = 1,
    Callback = function(value) selectedSaveSlot = value end
})

Tabs.Teleport:AddButton({
    Title = "传送一次",
    Callback = function()
        if selectedSaveSlot and savedPositions[selectedSaveSlot] then
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.CFrame = savedPositions[selectedSaveSlot]
            end
        else
            Fluent:Notify({ Title = "错误", Content = "选中的槽位还没有保存过位置！", Duration = 2 })
        end
    end
})

Tabs.Teleport:AddToggle("LoopTpToggle", {
    Title = "持续传送 (30次/秒)",
    Default = false,
    Callback = function(state)
        loopTpEnabled = state
        if loopTpEnabled then
            task.spawn(function()
                while loopTpEnabled do
                    if selectedSaveSlot and savedPositions[selectedSaveSlot] then
                        local char = LocalPlayer.Character
                        local hrp = char and char:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            hrp.AssemblyLinearVelocity = Vector3.zero
                            hrp.CFrame = savedPositions[selectedSaveSlot]
                        end
                    end
                    task.wait(1/30)
                end
            end)
        end
    end
})

