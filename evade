local autoRejoinOnRagdoll = false
local ragdollCheckTask = nil

Tabs.Auto:AddToggle("AutoRejoinToggle", {
    Title = "倒地/瘫痪后自动重连",
    Description = "检测到角色进入布娃娃倒地状态1秒后，自动重新加入游戏",
    Default = false,
    Callback = function(state)
        autoRejoinOnRagdoll = state
        if autoRejoinOnRagdoll then
            ragdollCheckTask = task.spawn(function()
                while autoRejoinOnRagdoll do
                    task.wait(0.3) 
                    local char = LocalPlayer.Character
                    local hum = char and char:FindFirstChildOfClass("Humanoid")
                    if hum then
                        local currentState = hum:GetState()
                        if currentState == Enum.HumanoidStateType.Ragdoll 
                        or currentState == Enum.HumanoidStateType.FallingDown 
                        or currentState == Enum.HumanoidStateType.Dead 
                        or hum.PlatformStand 
                        or hum.Health <= 0 then
                            task.wait(1)
                            if char and hum and (hum:GetState() == Enum.HumanoidStateType.Ragdoll or hum.PlatformStand or hum.Health <= 0) then
                                pcall(function() changeModeEvent:FireServer(true) end)
                                task.wait(3) 
                            end
                        end
                    end
                end
            end)
        else
            if ragdollCheckTask then
                task.cancel(ragdollCheckTask)
                ragdollCheckTask = nil
            end
        end
    end
})

local autoDeployEnabled = false
Tabs.Auto:AddToggle("AutoDeployToggle", {
    Title = "自动跳过大厅 (加入游戏)",
    Description = "在大厅无模型时自动加入游戏，并安全等待模型加载完毕",
