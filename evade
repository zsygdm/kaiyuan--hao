-- 模块三：ESP 透视 (极致优化 CPU 负担)
-- ==========================================
Tabs.ESP:AddSection("阵营透视控制")

local playerEspEnabled = false
local monsterEspEnabled = false
local playerHighlightColor = Color3.fromRGB(0, 255, 255)
local monsterHighlightColor = Color3.fromRGB(255, 0, 0)
local espCache = {}

Tabs.ESP:AddToggle("EnablePlayerESP", {
    Title = "开启玩家透视",
    Default = false,
    Callback = function(state) playerEspEnabled = state end
})

Tabs.ESP:AddToggle("EnableMonsterESP", {
    Title = "开启怪物透视",
    Default = false,
    Callback = function(state) monsterEspEnabled = state end
})

Tabs.ESP:AddColorpicker("PlayerColor", {
    Title = "玩家高亮与文字颜色",
    Default = Color3.fromRGB(0, 255, 255),
    Callback = function(color) playerHighlightColor = color end
})

Tabs.ESP:AddColorpicker("MonsterColor", {
    Title = "怪物方框与文字颜色",
    Default = Color3.fromRGB(255, 0, 0),
    Callback = function(color) monsterHighlightColor = color end
})

local targetFolderCache = nil

RunService.RenderStepped:Connect(function()
    if not playerEspEnabled and not monsterEspEnabled then
        for _, cache in pairs(espCache) do
            if cache.Highlight then cache.Highlight.Parent = nil end
            cache.Box.Visible = false
            cache.Text.Visible = false
        end
        return 
    end

    if not targetFolderCache or not targetFolderCache.Parent then
        targetFolderCache = Workspace:FindFirstChild("Game") and Workspace.Game:FindFirstChild("Players")
    end
    
    if not targetFolderCache then return end

    for _, entity in ipairs(targetFolderCache:GetChildren()) do
        if entity:IsA("Model") and entity.PrimaryPart then
            local root = entity.PrimaryPart
            
            if not espCache[entity] then
                local targetPlayerObj = Players:GetPlayerFromCharacter(entity)
                
                espCache[entity] = {
                    Highlight = Instance.new("Highlight"),
                    Box = Drawing.new("Square"),
                    Text = Drawing.new("Text"),
                    IsRealPlayer = (targetPlayerObj ~= nil),           
                    IsLocalPlayer = (targetPlayerObj == LocalPlayer)   
                }
                
                espCache[entity].Highlight.FillTransparency = 0.5
                espCache[entity].Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                espCache[entity].Box.Thickness = 1.5
                espCache[entity].Box.Filled = false
                espCache[entity].Text.Size = 14
                espCache[entity].Text.Center = true
                espCache[entity].Text.Outline = true
            end
            
            local cache = espCache[entity]
            
            if cache.IsLocalPlayer then continue end

            local shouldShow = (cache.IsRealPlayer and playerEspEnabled) or (not cache.IsRealPlayer and monsterEspEnabled)
            
            if not shouldShow then
                if cache.Highlight then cache.Highlight.Parent = nil end
                cache.Box.Visible = false
                cache.Text.Visible = false
                continue
            end

            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            local dist = math.floor((Camera.CFrame.Position - root.Position).Magnitude)
            
            if onScreen then
                if cache.IsRealPlayer then
                    cache.Highlight.Parent = entity
                    cache.Highlight.FillColor = playerHighlightColor
                    cache.Highlight.OutlineColor = playerHighlightColor
                    cache.Box.Visible = false
                    
                    cache.Text.Visible = true
                    cache.Text.Text = string.format("[玩家] %s\n%dm", entity.Name, dist)
                    cache.Text.Color = playerHighlightColor
                    cache.Text.Position = Vector2.new(pos.X, pos.Y + 30)
                else
                    cache.Highlight.Parent = nil 
                    local size = Vector2.new(2000 / pos.Z, 3000 / pos.Z)
                    cache.Box.Size = size
                    cache.Box.Position = Vector2.new(pos.X - size.X / 2, pos.Y - size.Y / 2)
                    cache.Box.Color = monsterHighlightColor
                    cache.Box.Visible = true
                    
                    cache.Text.Visible = true
                    cache.Text.Text = string.format("[怪物] %s\n%dm", entity.Name, dist)
                    cache.Text.Color = monsterHighlightColor
                    cache.Text.Position = Vector2.new(pos.X, pos.Y + (size.Y / 2) + 5)
                end
            else
                cache.Box.Visible = false
                cache.Text.Visible = false
            end
        end
    end
    
    for entity, cache in pairs(espCache) do
        if not entity or not entity.Parent then
            if cache.Highlight then cache.Highlight:Destroy() end
            if cache.Box then cache.Box:Remove() end
            if cache.Text then cache.Text:Remove() end
            espCache[entity] = nil
        end
    end
end)


