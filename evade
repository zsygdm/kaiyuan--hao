Tabs.Utility:AddSection("防掉线系统")

local antiAfkConnection = nil

Tabs.Utility:AddToggle("AntiAfkToggle", {
    Title = "开启防踢出 (移动端安全版)",
    Description = "静默拦截或模拟触摸，绝不会切换成电脑端UI",
    Default = false,
    Callback = function(state)
        if state then
            antiAfkConnection = LocalPlayer.Idled:Connect(function()
                -- 方案一：最高级静默拦截 (推荐，如果执行器支持 getconnections)
                pcall(function()
                    for _, v in pairs(getconnections(LocalPlayer.Idled)) do
                        if v.Disable then
                            v:Disable()
                        elseif v.Disconnect then
                            v:Disconnect()
                        end
                    end
                end)
                
                -- 方案二：移动端安全的触摸反馈 (即便方案一失效，也能完美防踢)
                -- 使用 ClickButton1 模拟屏幕单指点击，引擎识别为 Touch，不会切换成键鼠UI
                pcall(function()
                    VirtualUser:CaptureController()
                    VirtualUser:ClickButton1(Vector2.new(0, 0))
                end)
            end)
        else
            if antiAfkConnection then
                antiAfkConnection:Disconnect()
                antiAfkConnection = nil
            end
        end
    end
})

Tabs.Utility:AddSection("状态监视器 (右上角显示)")

local fpsEnabled = false
local fpsConnection = nil

Tabs.Utility:AddToggle("FpsToggle", {
    Title = "开启帧率 (FPS) 显示",
    Description = "每秒更新5次，动态变色",
    Default = false,
    Callback = function(state)
        fpsEnabled = state
        FpsLabel.Visible = state
        if fpsEnabled then
            local frames = 0
            local lastUpdate = tick()
            fpsConnection = RunService.RenderStepped:Connect(function()
                frames = frames + 1
                local now = tick()
                if now - lastUpdate >= 0.2 then
                    local fps = math.floor(frames / (now - lastUpdate))
                    frames = 0
                    lastUpdate = now
                    
                    FpsLabel.Text = "FPS: " .. tostring(fps)
                    
                    if fps >= 55 then
                        FpsLabel.TextColor3 = Color3.fromRGB(0, 255, 0) 
                    elseif fps >= 30 then
                        FpsLabel.TextColor3 = Color3.fromRGB(255, 165, 0) 
                    else
                        FpsLabel.TextColor3 = Color3.fromRGB(255, 0, 0) 
                    end
                end
            end)
        else
            if fpsConnection then
                fpsConnection:Disconnect()
                fpsConnection = nil
            end
        end
    end
})

local timerEnabled = false
local timerTask = nil

Tabs.Utility:AddToggle("TimerToggle", {
    Title = "开启挂机计时器",
    Description = "显示你总共挂机了多长时间",
    Default = false,
    Callback = function(state)
        timerEnabled = state
        TimerLabel.Visible = state
        if timerEnabled then
            local startTime = tick()
            timerTask = task.spawn(function()
                while timerEnabled do
                    local elapsed = math.floor(tick() - startTime)
                    local mins = math.floor(elapsed / 60)
                    local secs = elapsed % 60
                    TimerLabel.Text = string.format("挂机: %02d:%02d", mins, secs)
                    task.wait(1)
                end
            end)
        else
            if timerTask then
                task.cancel(timerTask)
                timerTask = nil
            end
            TimerLabel.Text = "挂机: 00:00"
        end
    end
})

